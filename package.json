{
  "name": "dstate",
  "version": "0.1.0",
  "description": "Agent-owned, self-evolving DAG+FSM state: durable memory, policy and intuition in one event-sourced store, with soft/hard transition enforcement.",
  "type": "module",
  "module": "src/index.js",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "dstate": "src/cli.js"
  },
  "scripts": {
    "test": "bun test",
    "test:integration": "bun test.js",
    "bench": "bun run bench/bench.js",
    "cli": "bun run src/cli.js"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "agent",
    "state-machine",
    "fsm",
    "dag",
    "event-sourcing",
    "memory",
    "policy",
    "bandit",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "libsql": "^0.5.29"
  }
}
